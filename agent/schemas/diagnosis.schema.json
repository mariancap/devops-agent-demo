{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagnosisOutput",
  "type": "object",
  "required": ["scenario_id", "diagnosis", "proposed_fix"],
  "additionalProperties": false,
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "diagnosis": {
      "type": "object",
      "required": ["category", "root_cause", "affected_file", "affected_line", "confidence"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": ["dockerfile", "docker-compose", "github-actions", "maven", "cross-file", "test-config"]
        },
        "root_cause": { "type": "string", "minLength": 1 },
        "affected_file": { "type": "string", "minLength": 1 },
        "affected_line": { "type": "integer", "minimum": 1 },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "proposed_fix": {
      "type": "object",
      "required": ["description", "patch_hint"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "patch_hint": { "type": "string", "minLength": 1 }
      }
    }
  }
}
